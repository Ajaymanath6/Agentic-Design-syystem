# Copy to .env.llm (gitignored). Refresh your AWS INI file on disk daily; paths stay stable.

GCP_PROJECT=your-gcp-project-id
AWS_REGION=us-east-1

# Path to AWS CLI-style credentials INI (quote paths with spaces)
LLM_AGENT_AWS_CREDENTIALS_FILE=/path/to/your/aws-credentials.ini

# Uncomment if your INI profile is not [default]
# AWS_PROFILE=default

# Optional overrides
# VERTEX_AWS_SECRET_ID=local/common/vertex-ai-credential
# GCP_LOCATION=us-east4
# VERTEX_MODEL=gemini-2.5-flash

# Theme context for prompts: legacy | smart | rag (default: smart)
# THEME_CONTEXT_MODE=smart
# THEME_CONTEXT_MAX_CHARS=6000
# THEME_CONTEXT_MAX_CHARS_EXTENDED=12000
# RAG_INDEX_DIR=/path/to/LLM agent/.rag-index  (after: npm run rag:reindex)
