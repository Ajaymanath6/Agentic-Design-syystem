    "componentGuidelines": {
      "button": {
        "cornerRadius": {
          "value": "6px",
          "tailwindClass": "rounded-md",
          "description": "ALL buttons MUST have 6px corner radius. Use rounded-md."
        },
        "secondaryBorderWidth": {
          "value": "1.5px",
          "tailwindClass": "border-[1.5px]",
          "description": "Outline/secondary buttons MUST have 1.5px border. Use border-[1.5px]."
        },
        "primary": {
          "description": "Main CTA button – green (secondary scale)",
          "defaultState": {
            "classes": "bg-secondary-600 text-white rounded-md",
            "logic": "Uses secondary-600 (#008B31) as background with white text. ALWAYS includes rounded-md."
          },
          "hoverState": {
            "classes": "hover:bg-secondary-800",
            "logic": "On hover, background changes to secondary-800 (#016323) for better visual feedback."
          },
          "focusState": {
            "classes": "focus:outline-none focus:ring-2 focus:ring-secondary-600",
            "logic": "Focus ring uses secondary-600."
          },
          "disabledState": {
            "classes": "disabled:opacity-50",
            "logic": "Disabled state reduces opacity to 50%."
          },
          "completeClasses": "bg-secondary-600 text-white hover:bg-secondary-800 focus:outline-none focus:ring-2 focus:ring-secondary-600 disabled:opacity-50 rounded-md px-4 py-2",
          "requiredClasses": ["bg-secondary-600", "text-white", "hover:bg-secondary-800", "rounded-md"],
          "whenToUse": "Use for main call-to-action buttons (e.g. I'm Interested, Get started)"
        },
        "secondary": {
          "description": "Outline/secondary button – primary (blue) or secondary (green) border and text",
          "defaultState": {
            "classes": "border-[1.5px] border-primary-600 text-primary-600 bg-transparent rounded-md",
            "logic": "Transparent background with primary-600 border and text. Use border-secondary-600 text-secondary-600 for green outline."
          },
          "hoverState": {
            "classes": "hover:bg-gray-100",
            "logic": "On hover, light gray background."
          },
          "completeClasses": "border-[1.5px] border-primary-600 text-primary-600 bg-transparent hover:bg-gray-100 rounded-md px-4 py-2",
          "whenToUse": "Use for secondary actions, outline style"
        },
        "neutral": {
          "description": "Neutral button – gray border and text",
          "defaultState": {
            "classes": "border border-gray-300 text-gray-700 bg-white rounded-md",
            "logic": "White background with gray-300 border and gray-700 text."
          },
          "hoverState": {
            "classes": "hover:bg-gray-100",
            "logic": "On hover, background changes to gray-100."
          },
          "completeClasses": "border border-gray-300 text-gray-700 bg-white hover:bg-gray-100 rounded-md px-4 py-2",
          "whenToUse": "Use for neutral actions without primary/secondary emphasis"
        }
      },
      "card": {
        "description": "Cards with borders and elevation",
        "styling": {
          "border": "border border-gray-200",
          "background": "bg-white",
          "padding": "p-6",
          "borderRadius": "rounded-lg",
          "shadow": "shadow-sm or shadow-md"
        },
        "logic": "Card borders use gray-200. Background white. Use semantic gray/white only.",
        "criticalRules": [
          "ALWAYS use border border-gray-200 for card borders",
          "ALWAYS use bg-white for card background",
          "ALWAYS use rounded-lg for card border radius"
        ]
      },
      "pieChart": {
        "description": "Lightweight proportion / category summary (no charting library). Used with sealed props title and data.",
        "rootClasses": "flex flex-col rounded-lg border border-gray-300 bg-white p-4 gap-3",
        "titleClasses": "pie-chart-title text-Mdblue-700 text-lg font-semibold",
        "dataLineClasses": "pie-chart-data text-sm text-gray-600 line-clamp-4",
        "visualClasses": "w-28 h-28 rounded-full bg-gradient-to-br from-primary-600 via-secondary-600 to-gray-400 ring-4 ring-gray-100",
        "legendDotClasses": "w-3 h-3 rounded-full shrink-0 (bg-primary-600 | bg-secondary-600 | bg-gray-400)",
        "logic": "Keep pie-chart-title and pie-chart-data class tokens so the agent runtime can inject props.title and props.data. Legend rows use text-sm text-gray-700 beside colored dots.",
        "criticalRules": [
          "Include classes pie-chart-title and pie-chart-data on the text nodes that receive title and data props",
          "Use only theme semantic colors (primary-*, secondary-*, gray-*, Mdblue-*) — no hex or inline color styles"
        ]
      },
      "barChart": {
        "description": "Category comparison without a chart library: labeled rows and horizontal bars (track + fill) plus a summary line.",
        "rootClasses": "flex flex-col rounded-lg border border-gray-300 bg-white p-4 gap-3",
        "titleClasses": "bar-chart-title text-Mdblue-700 text-lg font-semibold",
        "dataLineClasses": "bar-chart-data text-sm text-gray-600 line-clamp-3",
        "rowLabelClasses": "text-xs font-medium text-gray-700 w-24 shrink-0 truncate (avoid text-gray-600 on labels to keep prop-inference clean)",
        "trackClasses": "flex-1 h-3 rounded bg-gray-100 overflow-hidden min-w-0",
        "barFillClasses": "h-full rounded max-w-full (bg-primary-600 | bg-secondary-600 | bg-gray-400) with fractional widths e.g. w-11/12 w-2/3 w-1/2",
        "logic": "Preserve bar-chart-title and bar-chart-data for sealed props.title and props.data.",
        "criticalRules": [
          "Use bar-chart-title and bar-chart-data tokens on the title and summary text nodes",
          "Use semantic theme colors only for fills and borders"
        ]
      },
      "lineChart": {
        "description": "Trend-over-time placeholder: title, sparkline column strip (primary-600 bars), optional axis labels, data line.",
        "rootClasses": "flex flex-col rounded-lg border border-gray-300 bg-white p-4 gap-3",
        "titleClasses": "line-chart-title text-Mdblue-700 text-lg font-semibold",
        "sparklineClasses": "flex items-end justify-between gap-1 h-28 px-1 border-b border-gray-200",
        "barClasses": "w-2 rounded-t bg-primary-600 with varying h-* for trend shape",
        "axisLabelClasses": "text-xs text-gray-500 (prefer gray-500 over gray-600 for axis to avoid mistaken meta slots)",
        "dataLineClasses": "line-chart-data text-sm text-gray-600 line-clamp-3",
        "logic": "Preserve line-chart-title and line-chart-data for sealed props.title and props.data.",
        "criticalRules": [
          "Use line-chart-title and line-chart-data on the correct text nodes",
          "No hex or inline color styles; use primary-600 and gray borders/text from theme"
        ]
      },
      "researchPaperCard": {
        "description": "Scholarly preprint card (e.g. arXiv): badge, linked title, truncated abstract, authors, date.",
        "rootClasses": "flex flex-col rounded-lg border border-gray-300 bg-white p-3 gap-3",
        "badgeClasses": "inline-flex items-center gap-1 rounded-md bg-gray-50 px-2 py-1 text-xs font-semibold text-Mdblue-700",
        "titleClasses": "line-clamp-2 text-lg font-semibold text-Mdblue-700 hover:underline (anchor)",
        "summaryClasses": "truncate text-sm font-normal text-Mdblue-700",
        "metaClasses": "text-sm font-normal text-gray-600 (authors line-clamp-1, date whitespace-nowrap)",
        "footerRule": "border-t border-gray-100 pt-1 flex justify-between gap-2",
        "propsMapping": {
          "title": "Anchor with line-clamp-2",
          "summary": "Paragraph with truncate and text-Mdblue-700",
          "authors": "First text-gray-600 meta line",
          "publishedDate": "Second text-gray-600 meta line"
        },
        "criticalRules": [
          "Match project-card-style sealed prop wiring: summary uses the same truncate + text-Mdblue-700 pattern as project description",
          "Authors and publishedDate must use text-gray-600 in document order for prop injection"
        ]
      },
      "heading": {
        "h1": {
          "classes": "text-Mdblue-700 text-3xl font-bold",
          "logic": "Dark text (Mdblue-700) for main headings"
        },
        "h2": {
          "classes": "text-Mdblue-700 text-2xl font-semibold",
          "logic": "Dark text for secondary headings"
        },
        "h3": {
          "classes": "text-Mdblue-700 text-xl font-semibold",
          "logic": "Dark text for tertiary headings"
        }
      },
      "input": {
        "description": "Input fields – use semantic borders and text",
        "classes": "border border-gray-300 text-Mdblue-700 focus:border-primary-600 focus:outline-none focus:ring-0",
        "logic": "Gray-300 border by default; on focus use primary-600 border. Text color Mdblue-700. Use focus:ring-0 to override Flowbite/browser defaults.",
        "criticalRules": [
          "ALWAYS include focus:ring-0 and focus:outline-none",
          "Use border-gray-300 and focus:border-primary-600",
          "Text color: text-Mdblue-700 or text-gray-800"
        ]
      }
    },
    "aiInstructions": {
