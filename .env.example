# Local publish helper (npm run dev starts it with Vite; or: npm run dev:helper)
VITE_HELPER_BASE_URL=http://127.0.0.1:4301

# Optional: fire-and-forget blueprint POST after publish
# VITE_AGENT_BASE_URL=https://example.com/api

# Optional: override layout LLM base URL (default in dev: same-origin /api/layout-llm → port 4302)
# VITE_LAYOUT_LLM_BASE_URL=https://your-api.example.com
