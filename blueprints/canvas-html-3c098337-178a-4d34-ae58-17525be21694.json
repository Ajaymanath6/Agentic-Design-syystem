    "sourceHtml": "<div class=\"rounded-lg border border-brandcolor-strokeweak bg-brandcolor-white shadow-card w-[280px]\">\n  <div class=\"px-4 py-3\">\n    <h3 class=\"font-sans text-base font-semibold text-brandcolor-textstrong\">Title</h3>\n    <p class=\"mt-1 text-sm text-brandcolor-textweak\">Subtitle</p>\n    <p class=\"mt-2 text-sm leading-relaxed text-brandcolor-textweak\">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>\n  </div>\n  <div class=\"px-4 pb-3\">\n    <div class=\"w-full\"><label for=\"text-field-inline\" class=\"mb-1 block text-xs font-medium text-brandcolor-textstrong\">Text input field</label><input id=\"text-field-inline\" type=\"text\" name=\"textInputField\" autocomplete=\"off\" class=\"text-field-canvas-input w-full\" placeholder=\"Type here…\" required=\"\"></div>\n  </div>\n  <div class=\"px-4 pb-3\">\n    <div class=\"w-full\"><label for=\"confirm-pw-inline\" class=\"mb-1 block text-xs font-medium text-brandcolor-textstrong\">Confirm password</label><input id=\"confirm-pw-inline\" type=\"password\" name=\"confirmPassword\" autocomplete=\"new-password\" class=\"confirm-password-canvas-input w-full\" placeholder=\"••••••••\" required=\"\" minlength=\"8\"></div>\n  </div>\n  <div class=\"flex flex-col gap-2 px-4 pb-3\">\n    <button class=\"inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-medium text-brandcolor-white bg-brandcolor-primary hover:bg-brandcolor-primaryhover active:shadow-button-press focus:outline-none focus:ring-0 appearance-none border-0\">Primary Button</button>\n    <button type=\"button\" class=\"inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-medium text-brandcolor-white bg-brandcolor-secondary hover:bg-brandcolor-secondaryhover active:shadow-button-press focus:outline-none focus:ring-0 appearance-none border-0\">Secondary button</button>\n  </div>\n</div>"
